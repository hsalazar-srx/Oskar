# OSKAR — .gitignore
# Secrets and environment files — never commit
.env
.env.*
!.env.example
secrets.env
/etc/oskar/

# Python
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# Node / frontend
node_modules/
dist/
.next/
*.local
screenshot-out/
screenshot-run.mjs

# Docker volumes and runtime data
docker/data/
*.log

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# mypy / ruff
.mypy_cache/
.ruff_cache/

# Session state — regenerated each session, not committed
oskar-state.md
