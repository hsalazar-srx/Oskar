# OSKAR — Environment Variables Example (PRE-11)
# Copy to .env for local development:  cp .env.example .env
# Fill in real values in .env — it is gitignored and never committed.
#
# Production: DO NOT use this file.
# Run scripts/setup-server-secrets.sh on the OSKAR Linux VM.
# Secrets are written to /etc/oskar/secrets.env (owner root:oskar-app, mode 0640).

# ── PostgreSQL ────────────────────────────────────────────────────────────────
OSKAR_DB_HOST=localhost
OSKAR_DB_PORT=5432
OSKAR_DB_NAME=oskar
OSKAR_DB_USER=oskar_app
OSKAR_DB_PASSWORD=change-me-dev-only

# ── JWT ───────────────────────────────────────────────────────────────────────
# ADR-006: 60-min access token, 8h HttpOnly refresh cookie
# Generate key: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_HOURS=8

# ── Redis — ELIMINATED (ADR-007) ──────────────────────────────────────────────
# Redis has been removed from the OSKAR stack. Replacements:
#   Celery broker    → celery[sqlalchemy] (DATABASE_URL as broker)
#   JTI blocklist    → jti_blocklist table in PostgreSQL
#   Refresh tokens   → refresh_tokens table in PostgreSQL
#   Event stream     → HTTP polling GET /api/v1/ecn/{id} (15–30s)
# No REDIS_* variables required.

# ── Active Directory (LDAPS) ──────────────────────────────────────────────────
# ADR-006: LDAPS port 636 — plain LDAP 389 is NOT permitted (DISP Tier 1)
# AUTH_PROVIDER: "ldap" (production) | "entra" (future stub, PRE-3)
AUTH_PROVIDER=ldap
LDAP_SERVER=ldaps://srxglobal.local
LDAP_PORT=636
LDAP_BIND_DN=CN=oskar-svc,OU=ServiceAccounts,DC=srxglobal,DC=local
LDAP_BIND_PW=change-me-dev-only
LDAP_BASE_DN=DC=srxglobal,DC=local
LDAP_OSKAR_GROUP=OSKAR-Engineers

# ── Celery ────────────────────────────────────────────────────────────────────
# ADR-005: task signing key — generate: openssl rand -hex 32
CELERY_SECURITY_KEY=change-me-generate-with-openssl-rand-hex-32

# ── SMTP (Sprint 2 — PRE-9) ──────────────────────────────────────────────────
# Confirm SMTP host, port, and sender with Infrastructure before Sprint 2
SMTP_HOST=smtp.srxglobal.local
SMTP_PORT=587
SMTP_SENDER=oskar-noreply@srxglobal.local
SMTP_PASSWORD=change-me-dev-only

# ── ERP — Movex REST API ─────────────────────────────────────────────────────
MOVEX_API_URL=http://srxwebapp1.srxglobal.local/api
MOVEX_API_KEY=change-me-dev-only

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Comma-separated allowed CORS origins — tighten in production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=/api/v1

# ── Container Registry (PRE-10) ───────────────────────────────────────────────
# Harbor hostname confirmed by Manal ~2026-04-17
REGISTRY=apac-plm-ops.srxglobal.local
TAG=latest
